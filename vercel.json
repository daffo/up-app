{
  "buildCommand": "npx expo export --platform web && cp -r public/.well-known dist/.well-known",
  "outputDirectory": "dist",
  "headers": [
    {
      "source": "/.well-known/(.*)",
      "headers": [
        { "key": "Content-Type", "value": "application/json" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/((?!\\.well-known).*)", "destination": "/" }
  ]
}
